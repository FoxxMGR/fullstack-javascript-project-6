extends ../layouts/application.pug

block content
  a.btn.btn-primary.mb-3(href=route('newLabel'))= t('views.labels.new.signUp')
  table.table.table-striped
    thead
      tr
        th= t('views.labels.id')
        th= t('views.labels.name')
        th= t('views.labels.createdAt')
        th
    tbody
      each label in labels
        tr
          td= label.id
          td= label.name
          td= formatDate(label.createdAt)
          td
            a(href=route('editLabel', { id: label.id }))= t('views.labels.edit')
          td
            +buttonTo(route('deleteLabel', { id: label.id }), 'delete')(class="btn btn-link nav-link" value=t('views.labels.delete'))
