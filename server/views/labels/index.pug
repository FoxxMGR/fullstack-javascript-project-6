extends ../layouts/application.pug

block header
  = t('views.labels.index.header')

block content
  if isAuthenticated()
    p
      a.btn.btn-primary(href=route('newLabel'))= t('views.labels.index.new')
  table.table.table-striped
    thead
      tr
        th= t('views.labels.index.id')
        th= t('views.labels.index.name')
        th= t('views.labels.index.createdAt')
    tbody
      each label in labels
        tr
          td= label.id
          td= label.name
          td= formatDate(label.createdAt)
          if isAuthenticated()
            td
              a(href=route('editLabel', { id: label.id }))= t('views.labels.index.edit')
              |
              form(action=route('deleteLabel', { id: label.id }) method='post' style='display:inline')
                input(name="_method" type="hidden" value="delete")
                input(type='submit' value=t('views.labels.index.delete'))
