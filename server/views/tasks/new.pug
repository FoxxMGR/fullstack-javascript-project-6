extends ../layouts/application.pug

block header
  = t('views.tasks.new.header')

block content
  +formFor()(action=route('tasks') method='post')
    +input(task, 'name', errors)(type="text")
    .mb-3
      label(for='data_description')= t('views.tasks.new.description')
      textarea.form-control(id='data_description' name='data[description]')= task.description || ''
    .mb-3
      label(for='data_statusId')= t('views.tasks.new.status')
      select.form-control(id='data_statusId' name='data[statusId]')
        each status in statuses
          option(value=status.id selected=task.statusId === status.id)= status.name
    .mb-3
      label(for='data_executorId')= t('views.tasks.new.executor')
      select.form-control(id='data_executorId' name='data[executorId]')
        option(value='')= t('views.tasks.new.noExecutor')
        each user in users
          option(value=user.id selected=task.executorId === user.id)= `${user.firstName} ${user.lastName}`
    .mb-3
      label(for='labelIds')= t('views.tasks.new.labels')
      select.form-control(id='labelIds' name='labelIds' multiple)
        each label in labels
          option(value=label.id)= label.name
    +submit(task)(value=t('views.tasks.new.submit'))
