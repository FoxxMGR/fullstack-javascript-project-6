extends ../layouts/application.pug

block header
  = t('views.tasks.new.signUp')

block content
  +formFor()(action=route('updateTask', { id: task.id }) method='post')
    +input(task, 'name', errors)(type="text")
    +input(task, 'description', errors)(type="text")
    .mb-3
      label(for="data_statusId")= t('views.tasks.status')
      select.form-control(name="data[statusId]" id="data_statusId")
        option(value="")
        each status in statuses
          option(value=status.id selected=(task.statusId === status.id))= status.name
    .mb-3
      label(for="data_executorId")= t('views.tasks.executor')
      select.form-control(name="data[executorId]" id="data_executorId")
        option(value="")
        each user in users
          option(value=user.id selected=(task.executorId === user.id))= `${user.firstName} ${user.lastName}`
    .mb-3
      label(for="data_labels")= t('views.tasks.labels')
      select.form-control(name="data[labels]" id="data_labels" multiple)
        each label in labels
          option(value=label.id selected=(task.labels && task.labels.some(l => l.id === label.id)))= label.name
    +submit(task)(value=t('views.tasks.edit'))
