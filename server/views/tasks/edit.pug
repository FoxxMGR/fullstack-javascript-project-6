extends ../layouts/application.pug

block header
  = t('views.tasks.edit.header')

block content
  +formFor()(action=route('patchTask', { id: task.id }) method='post')
    input(name="_method" type="hidden" value="patch")
    +input(task, 'name', errors)(type="text")
    .mb-3
      label(for='data_description')= t('views.tasks.edit.description')
      textarea.form-control(id='data_description' name='data[description]')= task.description || ''
    .mb-3
      label(for='data_statusId')= t('views.tasks.edit.status')
      select.form-control(id='data_statusId' name='data[statusId]')
        each status in statuses
          option(value=status.id selected=task.statusId === status.id)= status.name
    .mb-3
      label(for='data_executorId')= t('views.tasks.edit.executor')
      select.form-control(id='data_executorId' name='data[executorId]')
        option(value='')= t('views.tasks.edit.noExecutor')
        each user in users
          option(value=user.id selected=task.executorId === user.id)= `${user.firstName} ${user.lastName}`
    .mb-3
      label(for='labelIds')= t('views.tasks.edit.labels')
      select.form-control(id='labelIds' name='labelIds' multiple)
        each label in labels
          option(value=label.id selected=task.labels && task.labels.some(l => l.id === label.id))= label.name
    +submit(task)(value=t('views.tasks.edit.submit'))
